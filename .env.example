ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Personal Access Token (비공개 저장소 자동 업데이트용)
# GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 권한: Contents (read-only) 만 선택
GH_TOKEN=
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 선택: 로그인 보호 (설정 안 하면 인증 없이 접근 가능)
APP_EMAIL=admin@example.com
APP_PASSWORD=your_secure_password_here

# 선택: 서버 사이드 일별 토큰 상한 (숫자, 0이면 무제한)
# 예: 500000 = 50만 토큰/일
SERVER_DAILY_TOKEN_LIMIT=0

# 선택: CORS 허용 도메인 (쉼표 구분). 미설정 시 전체 허용 (cloudflared 터널용)
# 예: http://localhost:5173,https://your-tunnel.trycloudflare.com
ALLOWED_ORIGINS=

# 선택: 클라우드 서버 URL (기기 간 동기화용). 미설정 시 로컬 서버 사용
# Render 배포 후 발급받은 URL 입력
# 예: https://ai-office-xxxx.onrender.com
VITE_API_BASE=

# 선택: 기기 간 동기화 인증 (VITE_API_BASE 설정 시 함께 사용)
# VITE_SYNC_EMAIL: 사용자/기업별 데이터를 분리 저장하는 식별자
# VITE_SYNC_PASSWORD: 서버 접근 인증 비밀번호
# 예: 회사A는 companya@example.com / 회사B는 companyb@example.com
VITE_SYNC_EMAIL=
VITE_SYNC_PASSWORD=
