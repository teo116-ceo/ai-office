{
  "name": "ai-office",
  "private": true,
  "version": "1.0.3",
  "description": "TEoVerse AI 오피스 — 지음과깃듬 AI 에이전트 시스템",
  "author": "TEoVerse",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "clean:dist": "node scripts/clean-dist.mjs",
    "prebuild": "npm run clean:dist",
    "typecheck": "npm run typecheck:app && npm run typecheck:server",
    "typecheck:app": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "test": "node --import tsx --test tests/taskRouting.test.ts tests/webhookValidation.test.ts tests/approvalPolicy.test.ts",
    "dev": "concurrently -n server,vite -c blue,green \"npm run server\" \"vite\"",
    "server": "tsx watch server/index.ts",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "electron:build": "node scripts/build-electron.mjs",
    "electron:pack": "node scripts/build-electron.mjs --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/node-cron": "^3.0.11",
    "@types/three": "^0.183.1",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.4.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "fflate": "^0.8.2",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pixel-agents": "^1.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
