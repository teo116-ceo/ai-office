{
  "name": "ai-office",
  "private": true,
  "version": "1.0.59",
  "description": "TEoVerse AI 오피스 — 지음과깃듬 AI 에이전트 시스템",
  "author": "TEoVerse",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "clean:dist": "node scripts/clean-dist.mjs",
    "prebuild": "npm run clean:dist",
    "typecheck": "npm run typecheck:app && npm run typecheck:server",
    "typecheck:app": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "test": "node --import tsx --import ./tests/setup.ts --test tests/taskTitle.test.ts tests/continuationService.test.ts tests/serverBudget.test.ts tests/taskRouting.test.ts tests/webhookValidation.test.ts tests/approvalPolicy.test.ts tests/rateLimiter.test.ts tests/llmUtils.test.ts tests/memoryService.test.ts tests/multiProviderApi.test.ts tests/agentExecution.test.ts",
    "lint": "eslint src server tests --max-warnings 50",
    "lint:fix": "eslint src server tests --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "dev": "chcp 65001 > nul && concurrently -n server,vite -c blue,green \"npm run server\" \"vite\"",
    "server": "tsx watch server/index.ts",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "electron:build": "node scripts/build-electron.mjs",
    "electron:pack": "node scripts/build-electron.mjs --dir",
    "build:server": "tsc -p tsconfig.server.build.json",
    "installer:graphics": "node scripts/generate-installer-graphics.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/generative-ai": "^0.24.1",
    "@types/node-cron": "^3.0.11",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.4.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "fflate": "^0.8.2",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.11"
  }
}
